---
import { Image } from 'astro:assets';

type Contributor = {
  login: string;
  html_url: string;
  avatar_url: string;
};

let contributors: Contributor[] = [];

try {
  const response = await fetch('https://api.github.com/repos/lanis-mobile/lanis/contributors', {
    headers: {
      Accept: 'application/vnd.github+json',
      'User-Agent': 'lanis-mobile.github.io',
    },
  });

  if (response.ok) {
    contributors = await response.json();
  }
} catch (error) {
  console.error('Error fetching GitHub contributors:', error);
}
---

<section class="mx-auto mb-16 max-w-[960px] px-[30px] md:mb-32">
  <h2 class="text-[var(--font-lg)]">Made with ♥ by</h2>
  <div id="contributors-list" class="mt-4 flex flex-wrap items-center gap-2">
    {contributors.map((contributor) => (
      <a class="inline-flex" title={contributor.login} href={contributor.html_url} target="_blank" rel="noreferrer">
        <Image src={contributor.avatar_url} alt={contributor.login} width={50} height={50} class="rounded-xl" loading="lazy" />
      </a>
    ))}
  </div>
  <div>
    <p><em><b>Lanis-Mobile</b> wird von einer Gruppe hessischer Schüler in Zusammenarbeit mit dem Schulamt Rüsselsheim entwickelt.</em></p>
    <p>
      Fragen und Rückmeldungen? Kommen Sie auf uns zu:<br />
      Henning Kauler:
      <a href="mailto:medienbildung.ssa.ruesselsheim@kultus.hessen.de">medienbildung.ssa.ruesselsheim@kultus.hessen.de</a><br />
      Alessio Caputo:
      <a href="mailto:lanis-mobile@alessioc42.dev">lanis-mobile@alessioc42.dev</a>
    </p>
  </div>
</section>
