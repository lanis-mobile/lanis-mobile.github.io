---
const screenshots = [
  '01.png',
  '02.png',
  '03.png',
  '04.png',
  '05.png',
  '06.png',
].map(
  (name) =>
    `https://raw.githubusercontent.com/alessioC42/lanis-mobile/main/fastlane/metadata/android/en-US/images/phoneScreenshots/${name}`,
);
---

<section class="mb-16 md:mb-32">
  <div class="mx-auto max-w-[960px] px-[30px]">
    <h2 class="text-[var(--font-lg)]">Screenshots</h2>
  </div>

  <div class="mx-auto max-w-[960px] px-0 md:px-[30px]">
    <div class="relative">
      <button
        type="button"
        data-carousel-prev
        aria-label="Previous screenshots"
        class="absolute top-1/2 left-2 z-10 hidden -translate-y-1/2 rounded-full bg-black/40 px-3 py-2 text-white md:block"
      >
        ‹
      </button>

      <div data-carousel class="overflow-x-auto scroll-smooth [scrollbar-width:none] [&::-webkit-scrollbar]:hidden">
        <div class="grid w-[800px] grid-cols-6 gap-5 p-8 md:w-auto md:p-[30px_0]">
          {screenshots.map((url) => (
            <a class="lightbox" href={url}>
              <img alt="" class="w-full cursor-pointer rounded-2xl shadow-[0_12px_48px_rgba(17,16,62,0.12)] transition-all duration-300 ease-in-out hover:scale-105 hover:shadow-[0_24px_48px_rgba(17,16,62,0.12)]" src={url} />
            </a>
          ))}
        </div>
      </div>

      <button
        type="button"
        data-carousel-next
        aria-label="Next screenshots"
        class="absolute top-1/2 right-2 z-10 hidden -translate-y-1/2 rounded-full bg-black/40 px-3 py-2 text-white md:block"
      >
        ›
      </button>
    </div>
  </div>
</section>

<script is:inline>
  const track = document.querySelector('[data-carousel]');
  const prev = document.querySelector('[data-carousel-prev]');
  const next = document.querySelector('[data-carousel-next]');

  if (track && prev && next) {
    const step = () => {
      const item = track.querySelector('a');
      return item ? item.clientWidth + 20 : 220;
    };

    prev.addEventListener('click', () => {
      track.scrollBy({ left: -step() * 2, behavior: 'smooth' });
    });

    next.addEventListener('click', () => {
      track.scrollBy({ left: step() * 2, behavior: 'smooth' });
    });
  }
</script>
