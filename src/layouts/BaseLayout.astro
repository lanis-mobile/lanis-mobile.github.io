---
import '../styles/global.css';
import GitHub from '../components/icons/GitHub.astro';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
}

const { title, description, ogImage = 'https://play-lh.googleusercontent.com/cbisJ2IlVLAB7VkLfjImwzIqiDP2LY2z5CaaCqeGIfmsPFjl0VSfrMmLgY98Go1Ajg=w416-h235' } = Astro.props;
---

<!DOCTYPE html>
<html dir="auto" lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <link rel="icon" href="/assets/favicon.png" />
    <link rel="stylesheet" href="/assets/tobi.css" />
  </head>
  <body class="relative m-0 flex min-h-screen flex-col p-0">
    <!-- GitHub Badge -->
    <a
      href="https://github.com/alessioc42/lanis-mobile"
      target="_blank"
      rel="noreferrer"
      class="group fixed right-0 top-0 z-50 block h-24 w-24 sm:h-28 sm:w-28"
      aria-label="View on GitHub"
    >
      <span
        aria-hidden="true"
        class="absolute inset-0 bg-[#151513] transition-colors duration-200 group-hover:bg-[#24292e] dark:bg-white dark:group-hover:bg-white [clip-path:polygon(100%_0,0_0,100%_100%)]"
      ></span>
      <span class="absolute right-3 top-3 text-2xl text-white drop-shadow-[0_1px_1px_rgba(0,0,0,0.7)] dark:text-[#151513] sm:right-4 sm:top-4 sm:text-3xl">
        <GitHub />
      </span>
    </a>

    <slot />

    <div class="pointer-events-none absolute inset-0 -z-20 overflow-hidden">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-full w-full translate-x-[20vw] -translate-y-[10vh]"
        preserveAspectRatio="xMinYMid slice"
        viewBox="0 0 1480 650"
      >
        <path
          class="bg-shape"
          d="M731.207 649.802C935.484 642.14 1480 337.325 1480 180.888c0-156.438-309.744-36.055-720-36.055S0-174.483 0 135.144c0 309.627 526.93 522.32 731.207 514.658z"
          fill-rule="evenodd"
        />
      </svg>
    </div>

    <script is:inline src="/assets/tobi.min.js"></script>
    <script is:inline>
      window.addEventListener('load', () => {
        // @ts-ignore
        new Tobi();
      });
    </script>
  </body>
</html>
